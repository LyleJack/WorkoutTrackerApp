{
  "name": "workouttracker",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "expo": "~55.0.0",
    "expo-constants": "~55.0.7",
    "expo-dev-client": "~55.0.16",
    "expo-document-picker": "~55.0.8",
    "expo-file-system": "~55.0.10",
    "expo-font": "~55.0.4",
    "expo-keep-awake": "~55.0.4",
    "expo-linking": "~55.0.7",
    "expo-notifications": "~55.0.11",
    "expo-router": "~55.0.4",
    "expo-sharing": "~55.0.11",
    "expo-sqlite": "~55.0.10",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gifted-charts": "^1.4.20",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~19.2.10",
    "typescript": "^5.8.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "@types/jest": "^29.5.0",
    "better-sqlite3": "^9.6.0",
    "@types/better-sqlite3": "^7.6.0",
    "jest-environment-node": "^29.7.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/__tests__"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^expo-sqlite$": "<rootDir>/__mocks__/expo-sqlite.ts",
      "^@react-native-async-storage/async-storage$": "<rootDir>/__mocks__/async-storage.ts",
      "^expo-constants$": "<rootDir>/__mocks__/expo-constants.ts",
      "^expo-notifications$": "<rootDir>/__mocks__/expo-notifications.ts",
      "^expo-file-system(/.*)?$": "<rootDir>/__mocks__/expo-file-system.ts",
      "^expo-sharing$": "<rootDir>/__mocks__/expo-sharing.ts",
      "^expo-document-picker$": "<rootDir>/__mocks__/expo-document-picker.ts",
      "^expo-font$": "<rootDir>/__mocks__/expo-font.ts",
      "^expo-linking$": "<rootDir>/__mocks__/expo-linking.ts",
      "^react-native$": "<rootDir>/__mocks__/react-native.ts",
      "^react-native-safe-area-context$": "<rootDir>/__mocks__/react-native-safe-area-context.ts",
      "^react-native-gifted-charts$": "<rootDir>/__mocks__/react-native-gifted-charts.ts",
      "^react-native-svg$": "<rootDir>/__mocks__/react-native-svg.ts"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.jest.json",
          "diagnostics": false
        }
      ]
    },
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  }
}
